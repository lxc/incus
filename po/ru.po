"incus storage volume import default backup0.tar.gz\n"
"    Создаёт новый пользовательский том, используя backup0.tar.gz в качестве "
"источника\n"
"\n"
"incus storage volume import default some-installer.iso installer --type=iso\n"
" Создаёт новый пользовательский том, хранящий some-installer.iso для "
"использования в качестве образа CD-ROM"

#: cmd/incus/storage_volume.go:1224
msgid ""
"incus storage volume info default foo\n"
"    Returns state information for a custom volume \"foo\" in pool "
"\"default\"\n"
"\n"
"incus storage volume info default virtual-machine/v1\n"
"    Returns state information for virtual machine \"v1\" in pool \"default\""
msgstr ""
"incus storage volume info default foo\n"
"    Возвращает информацию о состоянии пользовательского тома \"foo\" в пуле "
"\"default\"\n"
"\n"
"incus storage volume info default virtual-machine/v1\n"
"    Возвращает информацию о состоянии виртуальной машины \"v1\" в пуле "
"\"default\""

#: cmd/incus/storage_volume.go:1811
msgid ""
"incus storage volume set default data size=1GiB\n"
"    Sets the size of a custom volume \"data\" in pool \"default\" to 1 GiB\n"
"\n"
"incus storage volume set default virtual-machine/data snapshots.expiry=7d\n"
"    Sets the snapshot expiration period for a virtual machine \"data\" in "
"pool \"default\" to seven days"
msgstr ""
"incus storage volume set default data size=1GiB\n"
" Устанавливает размер пользовательского тома \"data\" в пуле \"default\" "
"равным 1 гигабайту\n"
"\n"
"incus storage volume set default virtual-machine/data snapshots.expiry=7d\n"
" Устанавливает срок хранения моментального снимка для виртуальной машины "
"\"data\" в пуле \"default\" равным семи дням"

#: cmd/incus/storage_volume.go:1958
